{
  "manifest_version": 3,
  "name": "Stat to do",
  "version": "1.0",
  "description": "extensão do site Stad to do para gerenciamento de tarefas",
  "icons": {
    "16": "img/LogoExt.png",
    "48": "img/LogoExt.png",
    "128": "img/LogoExt.png"
  },
  "background": {
    "service_worker": "js/servico.js"
  },
  "action": {
    "default_title": "Clique para abrir o painel"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["sidePanel"]
}
